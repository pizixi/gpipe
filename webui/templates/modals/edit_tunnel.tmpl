{{define "modals/edit_tunnel"}}
            <!-- 修改隧道 Modal -->
            <div id="editTunnelModal" class="modal">
                <div class="modal-content tunnel-modal">
                    <span class="close" onclick="closeModal('editTunnelModal')"
                        >&times;</span
                    >
                    <h2 data-i18n="edit_tunnel">修改隧道</h2>
                    <div class="tunnel-form-grid">
                        <div class="form-group tunnel-field-wide">
                            <label
                                for="editTunnelType"
                                data-i18n="protocol_type"
                                >协议类型：</label
                            >
                            <div class="select-shell">
                                <select
                                    id="editTunnelType"
                                    onchange="toggleTunnelTypeFields('edit')"
                                >
                                    <option value="0" data-i18n="tcp">TCP</option>
                                    <option value="1" data-i18n="udp">UDP</option>
                                    <option value="2" data-i18n="socks5">
                                        SOCKS5
                                    </option>
                                    <option value="3" data-i18n="http">HTTP</option>
                                    <option value="4" data-i18n="shadowsocks">
                                        Shadowsocks
                                    </option>
                                </select>
                                <span class="select-shell-indicator" aria-hidden="true">
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>
                        <div class="form-group tunnel-field-wide">
                            <label
                                for="editTunnelEncryption"
                                data-i18n="encryption_method"
                                >加密方式：</label
                            >
                            <div class="select-shell">
                                <select id="editTunnelEncryption">
                                    <option value="None" data-i18n="none">
                                        None
                                    </option>
                                    <option value="Aes128" data-i18n="aes128">
                                        Aes128
                                    </option>
                                    <option value="Xor" data-i18n="xor">Xor</option>
                                </select>
                                <span class="select-shell-indicator" aria-hidden="true">
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>
                        <div class="form-group tunnel-field-half">
                            <label
                                for="editTunnelReceiverInput"
                                data-i18n="receiver_id"
                                >隧道入口ID：</label
                            >
                            <div
                                class="player-combobox"
                                data-player-combobox="editTunnelReceiver"
                            >
                                <input
                                    type="hidden"
                                    id="editTunnelReceiver"
                                    value="0"
                                />
                                <input
                                    type="text"
                                    id="editTunnelReceiverInput"
                                    class="player-combobox-input"
                                    readonly
                                    autocomplete="off"
                                    spellcheck="false"
                                    onfocus="handleTunnelPlayerFocus('editTunnelReceiver')"
                                    onclick="openTunnelPlayerDropdown('editTunnelReceiver')"
                                    onkeydown="handleTunnelPlayerKeydown(event, 'editTunnelReceiver')"
                                    onblur="handleTunnelPlayerBlur('editTunnelReceiver')"
                                />
                                <button
                                    type="button"
                                    class="player-combobox-toggle"
                                    data-player-combobox-toggle="editTunnelReceiver"
                                    onclick="toggleTunnelPlayerDropdown('editTunnelReceiver')"
                                    aria-label="展开玩家列表"
                                    title="展开玩家列表"
                                >
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        aria-hidden="true"
                                    >
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </button>
                                <div
                                    id="editTunnelReceiverMenu"
                                    class="player-combobox-menu"
                                    role="listbox"
                                ></div>
                            </div>
                        </div>
                        <div class="form-group tunnel-field-half">
                            <label
                                for="editTunnelSenderInput"
                                data-i18n="sender_id"
                                >隧道出口ID：</label
                            >
                            <div
                                class="player-combobox"
                                data-player-combobox="editTunnelSender"
                            >
                                <input
                                    type="hidden"
                                    id="editTunnelSender"
                                    value="0"
                                />
                                <input
                                    type="text"
                                    id="editTunnelSenderInput"
                                    class="player-combobox-input"
                                    readonly
                                    autocomplete="off"
                                    spellcheck="false"
                                    onfocus="handleTunnelPlayerFocus('editTunnelSender')"
                                    onclick="openTunnelPlayerDropdown('editTunnelSender')"
                                    onkeydown="handleTunnelPlayerKeydown(event, 'editTunnelSender')"
                                    onblur="handleTunnelPlayerBlur('editTunnelSender')"
                                />
                                <button
                                    type="button"
                                    class="player-combobox-toggle"
                                    data-player-combobox-toggle="editTunnelSender"
                                    onclick="toggleTunnelPlayerDropdown('editTunnelSender')"
                                    aria-label="展开玩家列表"
                                    title="展开玩家列表"
                                >
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        aria-hidden="true"
                                    >
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </button>
                                <div
                                    id="editTunnelSenderMenu"
                                    class="player-combobox-menu"
                                    role="listbox"
                                ></div>
                            </div>
                        </div>
                        <div class="form-group tunnel-field-half">
                            <label for="editTunnelSource" data-i18n="source"
                                >监听地址：</label
                            >
                            <input
                                type="text"
                                id="editTunnelSource"
                                data-i18n-placeholder="source_placeholder"
                                placeholder="监听地址"
                            />
                        </div>
                        <div
                            class="form-group tunnel-field-half"
                            id="editTunnelEndpointGroup"
                            style="display: none"
                        >
                            <label for="editTunnelEndpoint" data-i18n="target"
                                >目标：</label
                            >
                            <input
                                type="text"
                                id="editTunnelEndpoint"
                                data-i18n-placeholder="target_placeholder"
                                placeholder="目标"
                            />
                        </div>
                        <div
                            class="form-group tunnel-field-half"
                            id="editTunnelUsernameGroup"
                            style="display: none"
                        >
                            <label for="editTunnelUsername" data-i18n="username"
                                >用户名：</label
                            >
                            <input
                                type="text"
                                id="editTunnelUsername"
                                data-i18n-placeholder="username_placeholder"
                                placeholder="用户名"
                            />
                        </div>
                        <div
                            class="form-group tunnel-field-half"
                            id="editTunnelPasswordGroup"
                            style="display: none"
                        >
                            <label for="editTunnelPassword" data-i18n="password"
                                >密码：</label
                            >
                            <div class="password-inline">
                                <input
                                    type="password"
                                    id="editTunnelPassword"
                                    data-i18n-placeholder="password_placeholder"
                                    placeholder="密码"
                                />
                                <button
                                    type="button"
                                    class="password-toggle-button"
                                    id="editTunnelPasswordToggle"
                                    onclick="
                                        toggleEditTunnelPasswordVisibility()
                                    "
                                    aria-label="显示密码"
                                    title="显示密码"
                                >
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        aria-hidden="true"
                                    >
                                        <path
                                            d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"
                                        ></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="form-group tunnel-field-half">
                            <label
                                for="editTunnelDescription"
                                data-i18n="description"
                                >描述：</label
                            >
                            <input
                                type="text"
                                id="editTunnelDescription"
                                data-i18n-placeholder="description_placeholder"
                                placeholder="描述"
                            />
                        </div>
                        <div class="form-group checkbox-card tunnel-field-half">
                            <label
                                for="editTunnelCompressed"
                                data-i18n="enable_compression"
                                >启用压缩：</label
                            >
                            <input type="checkbox" id="editTunnelCompressed" />
                        </div>
                    </div>

                    <div class="btn-group">
                        <button
                            class="btn btn-secondary"
                            onclick="closeModal('editTunnelModal')"
                            data-i18n="cancel_button"
                        >
                            取消
                        </button>
                        <button
                            class="btn btn-primary"
                            onclick="updateTunnel()"
                            data-i18n="update_button"
                        >
                            更新
                        </button>
                    </div>
                </div>
            </div>
{{end}}
