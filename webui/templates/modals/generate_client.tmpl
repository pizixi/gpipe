{{define "modals/generate_client"}}
            <div id="generateClientModal" class="modal">
                <div class="modal-content">
                    <span
                        class="close"
                        onclick="closeModal('generateClientModal')"
                        >&times;</span
                    >
                    <h2 data-i18n="generate_client">生成客户端</h2>
                    <div class="download-summary">
                        <div class="download-summary-item">
                            <span class="download-summary-label" data-i18n="id"
                                >ID</span
                            >
                            <strong id="generateClientPlayerId">-</strong>
                        </div>
                        <div class="download-summary-item">
                            <span
                                class="download-summary-label"
                                data-i18n="player_remark"
                                >备注</span
                            >
                            <strong id="generateClientPlayerRemark">-</strong>
                        </div>
                    </div>
                    <div class="form-group">
                        <label
                            for="generateClientTarget"
                            data-i18n="client_target"
                            >客户端版本：</label
                        >
                        <select id="generateClientTarget"></select>
                    </div>
                    <div
                        id="generateClientSettingsSummary"
                        class="settings-note"
                    ></div>
                    <div class="btn-group">
                        <button
                            class="btn btn-secondary"
                            type="button"
                            onclick="closeModal('generateClientModal')"
                            data-i18n="cancel_button"
                        >
                            取消
                        </button>
                        <button
                            class="btn btn-primary"
                            type="button"
                            onclick="downloadGeneratedClient()"
                            data-i18n="download_client"
                        >
                            生成并下载
                        </button>
                    </div>
                </div>
            </div>

{{end}}
