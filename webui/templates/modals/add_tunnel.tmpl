{{define "modals/add_tunnel"}}
            <!-- 添加隧道 Modal -->
            <div id="addTunnelModal" class="modal">
                <div class="modal-content tunnel-modal">
                    <span class="close" onclick="closeModal('addTunnelModal')"
                        >&times;</span
                    >
                    <h2 data-i18n="add_tunnel">添加隧道</h2>
                    <div class="tunnel-form-grid">
                        <div class="form-group tunnel-field-wide">
                            <label for="newTunnelType" data-i18n="protocol_type"
                                >协议类型：</label
                            >
                            <div class="select-shell">
                                <select
                                    id="newTunnelType"
                                    onchange="toggleTunnelTypeFields('new')"
                                >
                                    <option value="0" data-i18n="tcp">TCP</option>
                                    <option value="1" data-i18n="udp">UDP</option>
                                    <option value="2" data-i18n="socks5">
                                        SOCKS5
                                    </option>
                                    <option value="3" data-i18n="http">HTTP</option>
                                    <option value="4" data-i18n="shadowsocks">
                                        Shadowsocks
                                    </option>
                                </select>
                                <span class="select-shell-indicator" aria-hidden="true">
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>
                        <div class="form-group tunnel-field-wide">
                            <label
                                for="newTunnelEncryption"
                                data-i18n="encryption_method"
                                >加密方式：</label
                            >
                            <div class="select-shell">
                                <select id="newTunnelEncryption">
                                    <option value="None" data-i18n="none">
                                        None
                                    </option>
                                    <option value="Aes128" data-i18n="aes128">
                                        Aes128
                                    </option>
                                    <option value="Xor" data-i18n="xor">Xor</option>
                                </select>
                                <span class="select-shell-indicator" aria-hidden="true">
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>
                        <div class="form-group tunnel-field-half">
                            <label
                                for="newTunnelReceiverInput"
                                data-i18n="receiver_id"
                                >隧道入口ID：</label
                            >
                            <div
                                class="player-combobox"
                                data-player-combobox="newTunnelReceiver"
                            >
                                <input
                                    type="hidden"
                                    id="newTunnelReceiver"
                                    value="0"
                                />
                                <input
                                    type="text"
                                    id="newTunnelReceiverInput"
                                    class="player-combobox-input"
                                    readonly
                                    autocomplete="off"
                                    spellcheck="false"
                                    onfocus="handleTunnelPlayerFocus('newTunnelReceiver')"
                                    onclick="openTunnelPlayerDropdown('newTunnelReceiver')"
                                    onkeydown="handleTunnelPlayerKeydown(event, 'newTunnelReceiver')"
                                    onblur="handleTunnelPlayerBlur('newTunnelReceiver')"
                                />
                                <button
                                    type="button"
                                    class="player-combobox-toggle"
                                    data-player-combobox-toggle="newTunnelReceiver"
                                    onclick="toggleTunnelPlayerDropdown('newTunnelReceiver')"
                                    aria-label="展开玩家列表"
                                    title="展开玩家列表"
                                >
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        aria-hidden="true"
                                    >
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </button>
                                <div
                                    id="newTunnelReceiverMenu"
                                    class="player-combobox-menu"
                                    role="listbox"
                                ></div>
                            </div>
                        </div>
                        <div class="form-group tunnel-field-half">
                            <label
                                for="newTunnelSenderInput"
                                data-i18n="sender_id"
                                >隧道出口ID：</label
                            >
                            <div
                                class="player-combobox"
                                data-player-combobox="newTunnelSender"
                            >
                                <input
                                    type="hidden"
                                    id="newTunnelSender"
                                    value="0"
                                />
                                <input
                                    type="text"
                                    id="newTunnelSenderInput"
                                    class="player-combobox-input"
                                    readonly
                                    autocomplete="off"
                                    spellcheck="false"
                                    onfocus="handleTunnelPlayerFocus('newTunnelSender')"
                                    onclick="openTunnelPlayerDropdown('newTunnelSender')"
                                    onkeydown="handleTunnelPlayerKeydown(event, 'newTunnelSender')"
                                    onblur="handleTunnelPlayerBlur('newTunnelSender')"
                                />
                                <button
                                    type="button"
                                    class="player-combobox-toggle"
                                    data-player-combobox-toggle="newTunnelSender"
                                    onclick="toggleTunnelPlayerDropdown('newTunnelSender')"
                                    aria-label="展开玩家列表"
                                    title="展开玩家列表"
                                >
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        aria-hidden="true"
                                    >
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </button>
                                <div
                                    id="newTunnelSenderMenu"
                                    class="player-combobox-menu"
                                    role="listbox"
                                ></div>
                            </div>
                        </div>
                        <div class="form-group tunnel-field-half">
                            <label for="newTunnelSource" data-i18n="source"
                                >监听地址：</label
                            >
                            <input
                                type="text"
                                id="newTunnelSource"
                                data-i18n-placeholder="source_placeholder"
                                placeholder="监听地址"
                            />
                        </div>
                        <div
                            class="form-group tunnel-field-half"
                            id="newTunnelEndpointGroup"
                            style="display: none"
                        >
                            <label for="newTunnelEndpoint" data-i18n="target"
                                >目标：</label
                            >
                            <input
                                type="text"
                                id="newTunnelEndpoint"
                                data-i18n-placeholder="target_placeholder"
                                placeholder="目标"
                            />
                        </div>
                        <div
                            class="form-group tunnel-field-half"
                            id="newTunnelUsernameGroup"
                            style="display: none"
                        >
                            <label for="newTunnelUsername" data-i18n="username"
                                >用户名：</label
                            >
                            <input
                                type="text"
                                id="newTunnelUsername"
                                data-i18n-placeholder="username_placeholder"
                                placeholder="用户名"
                            />
                        </div>
                        <div
                            class="form-group tunnel-field-half"
                            id="newTunnelPasswordGroup"
                            style="display: none"
                        >
                            <label for="newTunnelPassword" data-i18n="password"
                                >密码：</label
                            >
                            <input
                                type="password"
                                id="newTunnelPassword"
                                data-i18n-placeholder="password_placeholder"
                                placeholder="密码"
                            />
                        </div>
                        <div class="form-group tunnel-field-half">
                            <label
                                for="newTunnelDescription"
                                data-i18n="description"
                                >描述：</label
                            >
                            <input
                                type="text"
                                id="newTunnelDescription"
                                data-i18n-placeholder="description_placeholder"
                                placeholder="描述"
                            />
                        </div>
                        <div class="form-group checkbox-card tunnel-field-half">
                            <label
                                for="newTunnelCompressed"
                                data-i18n="enable_compression"
                                >启用压缩：</label
                            >
                            <input
                                type="checkbox"
                                id="newTunnelCompressed"
                                checked
                            />
                        </div>
                    </div>

                    <div class="btn-group">
                        <button
                            class="btn btn-secondary"
                            onclick="closeModal('addTunnelModal')"
                            data-i18n="cancel_button"
                        >
                            取消
                        </button>
                        <button
                            class="btn btn-primary"
                            onclick="addTunnel()"
                            data-i18n="add_button"
                        >
                            添加
                        </button>
                    </div>
                </div>
            </div>

{{end}}
