{{define "sections/login"}}
            <!-- 登录表单 -->
            <div id="loginForm" class="login-form" style="display: none">
                <div class="language-switcher">
                    <button class="language-btn" onclick="changeLanguage('zh')">
                        中文
                    </button>
                    <button class="language-btn" onclick="changeLanguage('en')">
                        EN
                    </button>
                </div>
                <div class="login-shell">
                    <div class="login-showcase">
                        <div class="login-kicker">gpipe control</div>
                        <h2 data-i18n="login_intro_title">
                            统一管控玩家、隧道与客户端
                        </h2>
                        <p class="login-subtitle" data-i18n="login_intro_text">
                            一个后台完成玩家密钥管理、隧道维护与专属客户端分发。
                        </p>
                        <div class="login-feature-list">
                            <div class="login-feature">
                                <span class="login-feature-index">01</span>
                                <div>
                                    <h3 data-i18n="login_feature_players">
                                        玩家与密钥管理
                                    </h3>
                                    <p data-i18n="login_feature_players_desc">
                                        统一维护备注、密钥和在线状态。
                                    </p>
                                </div>
                            </div>
                            <div class="login-feature">
                                <span class="login-feature-index">02</span>
                                <div>
                                    <h3 data-i18n="login_feature_tunnels">
                                        隧道编排
                                    </h3>
                                    <p data-i18n="login_feature_tunnels_desc">
                                        快速查询、修改和启停传输隧道。
                                    </p>
                                </div>
                            </div>
                            <div class="login-feature">
                                <span class="login-feature-index">03</span>
                                <div>
                                    <h3 data-i18n="login_feature_clients">
                                        客户端生成
                                    </h3>
                                    <p data-i18n="login_feature_clients_desc">
                                        为每个玩家生成内置连接参数的专属二进制。
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="login-panel">
                        <div class="login-brand">
                            <div class="login-kicker">admin sign in</div>
                            <h2 data-i18n="login_title">登录</h2>
                            <p
                                class="login-subtitle"
                                data-i18n="login_subtitle"
                            >
                                输入后台账号后进入管理系统
                            </p>
                        </div>
                        <form onsubmit="handleLoginSubmit(event)">
                            <div class="form-group">
                                <input
                                    type="text"
                                    id="username"
                                    data-i18n-placeholder="username_placeholder"
                                    placeholder="用户名"
                                    autocomplete="username"
                                />
                            </div>
                            <div class="form-group">
                                <input
                                    type="password"
                                    id="password"
                                    data-i18n-placeholder="password_placeholder"
                                    placeholder="密码"
                                    autocomplete="current-password"
                                />
                            </div>
                            <button
                                type="submit"
                                class="btn btn-primary"
                                data-i18n="login_button"
                            >
                                登录
                            </button>
                        </form>
                    </div>
                </div>
            </div>

{{end}}
